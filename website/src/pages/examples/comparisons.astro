---
import { getEntry, render } from "astro:content";
import BaitingDefaultMobile from "../../components/examples/BaitingDefaultMobile.astro";
import BaitingSongStyleMobile from "../../components/examples/BaitingSongStyleMobile.astro";
import MobileSiteComparison from "../../components/examples/MobileSiteComparison.astro";
import QingxuDefaultMobile from "../../components/examples/QingxuDefaultMobile.astro";
import QingxuSongStyleMobile from "../../components/examples/QingxuSongStyleMobile.astro";
import MarkdownProse from "../../components/MarkdownProse.astro";
import { baitingCase, qingxuCase } from "../../data/cases";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";

const entry = await getEntry("examples", "comparisons/overview");
if (!entry) throw new Error("Missing comparison content");
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | SongStyle AI Design System`} description={entry.data.description}>
  <article class="container comparison-page">
    <MarkdownProse><Content /></MarkdownProse>
    <section>
      <h2>白汀 Baiting</h2>
      <MobileSiteComparison data={baitingCase}>
        <BaitingDefaultMobile slot="default" data={baitingCase} />
        <BaitingSongStyleMobile slot="songstyle" data={baitingCase} />
      </MobileSiteComparison>
    </section>
    <section>
      <h2>清序 Qingxu</h2>
      <MobileSiteComparison data={qingxuCase}>
        <QingxuDefaultMobile slot="default" data={qingxuCase} />
        <QingxuSongStyleMobile slot="songstyle" data={qingxuCase} />
      </MobileSiteComparison>
    </section>
    <nav class="comparison-links" aria-label="比较工具">
      <a href={withBase("/prompts/design-review/compare-default-and-songstyle/")}>比较 Prompt</a>
      <a href={withBase("/checklist/")}>共享审查清单</a>
    </nav>
  </article>
</BaseLayout>

<style is:global>
  .comparison-page { padding-block: var(--song-space-section-compact); }
  .comparison-page section { margin-top: var(--song-space-section-compact); }
  .comparison-page h2 { font-family: var(--song-typography-family-display); font-size: var(--song-typography-size-title); font-weight: 400; }
  .comparison-page .comparison-links { display: flex; flex-wrap: wrap; gap: var(--song-space-scale-6); margin-top: var(--song-space-section-compact); }
  .comparison-page .comparison-links a { color: var(--song-color-accent-primary); }
</style>
