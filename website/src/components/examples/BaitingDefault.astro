---
import type { CaseStudy } from "../../data/cases";
import { withBase } from "../../lib/paths";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<section class="baiting-default" aria-label="白汀普通 AI 默认方案" data-testid="baiting-default">
  <img src={withBase(data.image)} alt={data.imageAlt} />
  <div class="visual-overlay" aria-hidden="true"></div>
  <div class="default-content">
    <p class="badges">{data.brand} · {data.position} · 当代生活精选</p>
    <h3>{data.headline}</h3>
    <p class="description">{data.description}</p>
    <a href="#baiting-details">{data.action}</a>
    <div class="default-cards">
      {data.features.map((feature) => (
        <article><span>{feature.label}</span><strong>{feature.value}</strong></article>
      ))}
    </div>
  </div>
</section>

<style>
  .baiting-default {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    border-radius: var(--song-shape-radius-large);
    background: #4a3043;
    color: #fff;
  }
  img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .visual-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 75% 20%, rgb(255 206 224 / 0.62), transparent 34%),
      linear-gradient(120deg, rgb(45 21 67 / 0.96), rgb(102 52 104 / 0.62) 58%, rgb(255 195 172 / 0.3));
  }
  .default-content {
    position: relative;
    display: grid;
    align-content: end;
    min-height: 520px;
    padding: var(--song-space-scale-8);
  }
  .badges {
    margin: 0 0 var(--song-space-scale-4);
    font-size: var(--song-typography-size-small);
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  h3 {
    max-width: 18ch;
    margin: 0;
    font-size: clamp(var(--song-typography-size-title), 6vw, var(--song-typography-size-display));
    line-height: 1.08;
    text-shadow: 0 4px 28px rgb(31 11 43 / 0.52);
  }
  .description {
    max-width: 42rem;
    margin: var(--song-space-scale-4) 0;
    line-height: var(--song-typography-line-height-body);
  }
  a {
    justify-self: start;
    padding: var(--song-space-scale-3) var(--song-space-scale-5);
    border-radius: 999px;
    background: #7c3aed;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 24px rgb(52 20 76 / 0.35);
  }
  .default-cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--song-space-scale-3);
    margin-top: var(--song-space-scale-6);
  }
  .default-cards article {
    display: grid;
    gap: var(--song-space-scale-2);
    padding: var(--song-space-scale-4);
    border: 1px solid rgb(255 255 255 / 0.44);
    border-radius: var(--song-shape-radius-control);
    background: rgb(255 255 255 / 0.18);
    backdrop-filter: blur(12px);
  }
  .default-cards span { font-size: var(--song-typography-size-small); }
  @media (max-width: 620px) {
    .default-cards { grid-template-columns: 1fr; }
  }
</style>
