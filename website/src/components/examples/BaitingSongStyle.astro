---
import type { CaseStudy } from "../../data/cases";
import { withBase } from "../../lib/paths";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<section id="baiting-songstyle" class="baiting-songstyle" aria-label="白汀 SongStyle 改写" data-testid="baiting-songstyle">
  <div class="story">
    <p class="eyebrow">{data.brand} · {data.position}</p>
    <h3>{data.headline}</h3>
    <p>{data.description}</p>
    <a href="#baiting-details">{data.action}</a>
  </div>
  <div class="object-stage">
    <img src={withBase(data.image)} alt={data.imageAlt} />
  </div>
  <dl id="baiting-details">
    {data.features.map((feature) => (
      <div><dt>{feature.label}</dt><dd>{feature.value}</dd></div>
    ))}
  </dl>
</section>

<style>
  .baiting-songstyle {
    display: grid;
    gap: var(--song-space-scale-8);
    padding: var(--song-space-scale-8);
    border: var(--song-shape-border-width) solid var(--song-color-border-subtle);
    border-radius: var(--song-shape-radius-large);
    background: var(--song-color-surface-default);
  }
  .story { align-self: center; }
  h3 { max-width: 12ch; margin: 0; font-family: var(--song-typography-family-display); font-size: var(--song-typography-size-title); font-weight: 400; line-height: 1.4; }
  .story p:not(.eyebrow) { max-width: 34rem; color: var(--song-color-text-secondary); line-height: var(--song-typography-line-height-relaxed); }
  .story a { color: var(--song-color-accent-primary); text-underline-offset: var(--song-space-scale-2); }
  .object-stage { min-height: 300px; overflow: hidden; background: var(--song-color-background-canvas); }
  .object-stage img { display: block; width: 100%; height: 100%; min-height: 300px; object-fit: cover; object-position: center; }
  dl { display: grid; gap: var(--song-space-scale-4); margin: 0; }
  dl div { padding-top: var(--song-space-scale-3); border-top: var(--song-shape-border-width) solid var(--song-color-border-subtle); }
  dt { color: var(--song-color-text-secondary); font-size: var(--song-typography-size-small); }
  dd { margin: var(--song-space-scale-2) 0 0; }
  @media (min-width: 760px) {
    .baiting-songstyle { grid-template-columns: 1fr 1fr; padding: var(--song-space-scale-12); }
    dl { grid-column: 1 / -1; grid-template-columns: repeat(3, 1fr); }
  }
</style>
