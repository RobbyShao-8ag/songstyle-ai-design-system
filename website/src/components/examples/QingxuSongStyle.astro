---
import type { CaseStudy } from "../../data/cases";
import { withBase } from "../../lib/paths";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<section class="qingxu-songstyle" aria-label="清序 SongStyle 改写" data-testid="qingxu-songstyle">
  <header>
    <p class="eyebrow">{data.brand} · {data.position}</p>
    <h3>{data.headline}</h3>
    <p>{data.description}</p>
    <a href="#qingxu-workflow">{data.action}</a>
  </header>
  <img class="research-image" src={withBase(data.image)} alt={data.imageAlt} />
  <div id="qingxu-workflow" class="workflow">
    {data.features.map((feature) => (
      <article><span>{feature.label}</span><h4>{feature.value}</h4></article>
    ))}
  </div>
</section>

<style>
  .qingxu-songstyle { padding: var(--song-space-scale-8); border: var(--song-shape-border-width) solid var(--song-color-border-subtle); border-radius: var(--song-shape-radius-large); background: var(--song-color-surface-default); }
  header { max-width: 48rem; }
  h3 { max-width: 15ch; margin: 0; font-family: var(--song-typography-family-display); font-size: var(--song-typography-size-title); font-weight: 400; line-height: 1.4; }
  header p:not(.eyebrow) { color: var(--song-color-text-secondary); line-height: var(--song-typography-line-height-relaxed); }
  header a { color: var(--song-color-accent-primary); text-underline-offset: var(--song-space-scale-2); }
  .research-image { display: block; width: 100%; height: clamp(260px, 42vw, 520px); margin-top: var(--song-space-scale-12); object-fit: cover; object-position: center; }
  .workflow { display: grid; gap: var(--song-space-scale-4); margin-top: var(--song-space-scale-12); }
  .workflow article { padding-top: var(--song-space-scale-4); border-top: var(--song-shape-border-width) solid var(--song-color-border-subtle); }
  .workflow span { color: var(--song-color-accent-primary); font-size: var(--song-typography-size-small); }
  .workflow h4 { margin: var(--song-space-scale-3) 0; font-family: var(--song-typography-family-display); font-size: var(--song-typography-size-lead); font-weight: 400; }
  @media (min-width: 760px) {
    .qingxu-songstyle { padding: var(--song-space-scale-12); }
    .workflow { grid-template-columns: repeat(3, 1fr); }
  }
</style>
