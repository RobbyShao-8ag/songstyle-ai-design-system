---
import type { CaseStudy } from "../../data/cases";
import { withBase } from "../../lib/paths";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<section class="qingxu-default-mobile" data-testid="qingxu-default-mobile">
  <header>
    <p>{data.brand} · {data.position}</p>
    <h3>{data.headline}</h3>
    <p class="description">{data.description}</p>
    <a href="#qingxu-default-brief">{data.action}</a>
  </header>
  <div class="dashboard">
    <img src={withBase(data.image)} alt={data.imageAlt} />
  </div>
  <div class="feature-grid" id="qingxu-default-brief">
    {data.features.map((feature) => (
      <article><span>{feature.label}</span><strong>{feature.value}</strong></article>
    ))}
  </div>
  <aside class="promise">
    <strong>研究闭环</strong>
    <p>{data.businessGoal}</p>
  </aside>
</section>

<style>
  .qingxu-default-mobile {
    min-height: 100%;
    padding: 30px 22px;
    background: #f6f4ee;
    color: #252821;
    text-align: center;
  }

  header p:first-child {
    color: #50685f;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  h3 {
    max-width: 15ch;
    margin: 20px auto;
    font-size: 31px;
    line-height: 1.22;
  }

  .description {
    color: #5c615a;
    line-height: 1.72;
  }

  a {
    display: inline-block;
    margin-top: 18px;
    padding: 12px 22px;
    border-radius: 8px;
    background: #435f56;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid #9b7c55;
    outline-offset: 4px;
  }

  a:active {
    transform: translateY(1px);
  }

  .dashboard {
    position: relative;
    overflow: hidden;
    margin-top: 34px;
    border: 1px solid rgb(68 87 79 / 0.18);
    border-radius: 8px;
    background: #e5e1d8;
  }

  .dashboard img {
    display: block;
    width: 100%;
    height: 270px;
    object-fit: cover;
    opacity: 0.88;
    filter: saturate(0.88) contrast(0.98);
  }

  .feature-grid {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }

  .feature-grid article {
    display: grid;
    gap: 8px;
    padding: 18px;
    border: 1px solid rgb(68 87 79 / 0.18);
    border-radius: 8px;
    background: #fffdf8;
  }

  .feature-grid span {
    color: #61756e;
    font-size: 12px;
  }

  .promise {
    margin-top: 14px;
    padding: 18px;
    border: 1px solid rgb(68 87 79 / 0.18);
    border-radius: 8px;
    background: #fffdf8;
    text-align: left;
  }

  .promise p {
    color: #5c615a;
    line-height: 1.72;
  }
</style>
