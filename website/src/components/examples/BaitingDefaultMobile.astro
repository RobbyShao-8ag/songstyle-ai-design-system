---
import type { CaseStudy } from "../../data/cases";
import { withBase } from "../../lib/paths";

interface Props {
  data: CaseStudy;
}

const { data } = Astro.props;
---

<section class="baiting-default-mobile" data-testid="baiting-default-mobile">
  <header class="hero">
    <p>{data.brand} · {data.position}</p>
    <h3>{data.headline}</h3>
    <p class="description">{data.description}</p>
    <a href="#baiting-default-brief">{data.action}</a>
  </header>
  <figure>
    <img src={withBase(data.image)} alt={data.imageAlt} />
  </figure>
  <div class="cards">
    {data.features.map((feature) => (
      <article><span>{feature.label}</span><strong>{feature.value}</strong></article>
    ))}
  </div>
  <div class="promise" id="baiting-default-brief">
    <strong>安心日常</strong>
    <p>{data.businessGoal}</p>
  </div>
</section>

<style>
  .baiting-default-mobile {
    min-height: 100%;
    padding: 26px 22px 28px;
    background: #f7f4ec;
    color: #2d2b27;
    font-family: var(--song-typography-family-body);
  }

  .hero {
    display: grid;
    gap: 16px;
    padding: 6px 0 22px;
  }

  .hero p:first-child {
    margin: 0;
    color: #6d695f;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  h3 {
    max-width: 14ch;
    margin: 0;
    font-size: 32px;
    line-height: 1.18;
  }

  .description {
    margin: 0;
    color: #5e5a52;
    line-height: 1.65;
  }

  a {
    justify-self: start;
    padding: 12px 18px;
    border-radius: 8px;
    background: #4f6259;
    color: #fff;
    font-weight: 700;
    text-decoration: none;
  }

  a:focus-visible {
    outline: 3px solid #9b7c55;
    outline-offset: 4px;
  }

  a:active {
    transform: translateY(1px);
  }

  figure {
    margin: 0;
    overflow: hidden;
    border-radius: 8px;
    background: #e4e0d6;
  }

  figure img {
    display: block;
    width: 100%;
    height: 250px;
    object-fit: cover;
  }

  .cards {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }

  .cards article,
  .promise {
    padding: 16px;
    border: 1px solid rgb(84 93 85 / 0.18);
    border-radius: 8px;
    background: #fffdf8;
    color: #2d2b27;
  }

  .cards span {
    display: block;
    margin-bottom: 8px;
    font-size: 12px;
    opacity: 0.82;
  }

  .cards strong {
    font-size: 20px;
  }

  .promise {
    margin-top: 12px;
  }

  .promise p {
    color: #676158;
    line-height: 1.7;
  }
</style>
