{
  "typography": {
    "family": {
      "$type": "fontFamily",
      "body": {
        "$value": ["Inter", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", "sans-serif"],
        "$description": "Legible sans-serif stack for interface and body text."
      },
      "display": {
        "$value": ["Source Han Serif SC", "Noto Serif SC", "Songti SC", "STSong", "serif"],
        "$description": "Serif stack for measured display expression."
      }
    },
    "size": {
      "$type": "dimension",
      "small": { "$value": { "value": 14, "unit": "px" }, "$description": "Small supporting text." },
      "body": { "$value": { "value": 16, "unit": "px" }, "$description": "Default body text." },
      "lead": { "$value": { "value": 18, "unit": "px" }, "$description": "Introductory body text." },
      "title-small": { "$value": { "value": 24, "unit": "px" }, "$description": "Small section title." },
      "title": { "$value": { "value": 32, "unit": "px" }, "$description": "Default section title." },
      "display": { "$value": { "value": 48, "unit": "px" }, "$description": "Primary display title." },
      "display-large": { "$value": { "value": 64, "unit": "px" }, "$description": "Large exhibition title." }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.4, "$description": "Tight display line height." },
      "body": { "$value": 1.6, "$description": "Default body line height." },
      "relaxed": { "$value": 1.8, "$description": "Relaxed reading line height." }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400, "$description": "Default text weight." },
      "medium": { "$value": 500, "$description": "Measured emphasis weight." },
      "semibold": { "$value": 600, "$description": "Strong but restrained emphasis." }
    }
  }
}
