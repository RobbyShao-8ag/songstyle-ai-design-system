{
  "motion": {
    "duration": {
      "$type": "duration",
      "quick": { "$value": { "value": 120, "unit": "ms" }, "$description": "Immediate control feedback." },
      "enter": { "$value": { "value": 220, "unit": "ms" }, "$description": "Default entrance and state transition." },
      "slow": { "$value": { "value": 420, "unit": "ms" }, "$description": "Measured exhibition transition." }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0, 0, 1], "$description": "Default calm easing." },
      "emphasized": { "$value": [0.16, 1, 0.3, 1], "$description": "Expressive but restrained easing." }
    },
    "distance": {
      "$type": "dimension",
      "small": { "$value": { "value": 8, "unit": "px" }, "$description": "Small motion distance." },
      "medium": { "$value": { "value": 16, "unit": "px" }, "$description": "Default motion distance." }
    }
  }
}
